# =============================================================================
# このファイルは「ひな型」です。実際の値はプロジェクト直下の .env.local に書きます。
#
# 手順:
#   1. このファイルをコピーして .env.local を新規作成する（名前は .env.local 固定）
#   2. 各 KEY の右側に、下の説明どおり「値」を貼る
#   3. .env.local は Git に含めない（通常は .gitignore 済み）
#
# 開発サーバーは .env.local を読み込みます。変更したら `npm run dev` を再起動。
# =============================================================================

# 任意。本番の Health Park のトップ URL（末尾 / なし）。OGP・canonical の絶対 URL 用。
# 未設定時は Vercel なら VERCEL_URL、それ以外は metadataBase なし（相対パスのみ）。
# NEXT_PUBLIC_SITE_URL=https://health.tennis-park-community.com

# Firebase コンソール → プロジェクトの設定 → 全般 → マイアプリ → SDK の設定・構成
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Analytics を使う場合のみ
# NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# 地図等を使う場合（Google Cloud で API を有効化）
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- お知らせ（ブログ API）---
# ヘルス用ブログをブラウザで開いたときのアドレスバーと「同じホスト」の https URL。
# 例: https://blog-health.tennis-park-community.com  （末尾に / は付けない）
# 【禁止】Health Park 自身（health.tennis-park-community.com）を入れないこと。
#   ブログ専用ホストと異なる。誤ると /api/blog が 404 になる。
# 本番の確定ドメインは Web／インフラ担当に確認すること。
NEXT_PUBLIC_HEALTH_BLOG_ORIGIN=
# アプリは同一オリジン /api/health-blog を経由してブログ /api/blog を取得する。
# ブラウザが別ドメインを直接叩かないため、通常はブログ側の CORS 設定は不要。

# 任意。embed iframe の URL に付与するクエリ（先頭の ? はあってもなくても可）。
# ブログが embed 用 CTA レイアウト切替等で参照する場合に設定。例: embed_host=health-park
# NEXT_PUBLIC_HEALTH_BLOG_EMBED_QUERY=embed_host=health-park

# 任意。お知らせ詳細の iframe が postMessage で高さを受け取るまでの「最低の高さ」（px 数値のみ）。
# 未設定時は min(96vh, 14000px)。超長文だけ足りないときに上げる。短い記事では下に余白が出やすい。
# NEXT_PUBLIC_ANNOUNCEMENT_EMBED_FALLBACK_MIN_PX=12000

# 任意。一覧 API の `tag` / `category` クエリ用。ブログ管理の「タグ・カテゴリの slug」と
# 一致させる。誤ると 0 件になるため、迷ったら両方とも空にして /api/blog が全件返るか先に確認。
# 値は GET .../api/blog/tags 等でブログ担当に確認。
# NEXT_PUBLIC_HEALTH_BLOG_TAG=
# 公開先が「カテゴリ」で管理されている場合に使用（API の category パラメータ）
# NEXT_PUBLIC_HEALTH_BLOG_CATEGORY=
# 記事の publicationTarget フィールドで絞る（ブログ API がクエリ対応している場合のみ）
# 例: health。記事が tennis のままだと、このフィルタではヒットしない。
# 単記事取得（/api/health-blog/[slug]）にも同じ 3 つを付与する。一覧に出るのに記事で 404 になるのを防ぐ。
# NEXT_PUBLIC_HEALTH_BLOG_PUBLICATION_TARGET=

# --- Google AdSense（記録ページのフォーム直下に固定サイズで表示）---
# tennis-park-community.com 承認済みの同一パブリッシャー ID・ユニット slot を指定。
# 両方とも未設定のときは広告コンポーネントは何も描画しません。
# NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-xxxxxxxxxxxxxxxx
# NEXT_PUBLIC_ADSENSE_SLOT=xxxxxxxxxx
# （検証用）モバイルだけ別ユニットにしたい場合に使用。未設定なら共通 slot。
# NEXT_PUBLIC_ADSENSE_SLOT_MOBILE=yyyyyyyyyy
# 広告枠サイズ（固定）。未設定または 320x100（既定）／300x250 のみ対応。
# 端末別に分ける場合（未設定なら NEXT_PUBLIC_ADSENSE_UNIT_SIZE の値を使用）。
# 例: PC は 300x250、スマホは 320x100
# NEXT_PUBLIC_ADSENSE_UNIT_SIZE_DESKTOP=300x250
# NEXT_PUBLIC_ADSENSE_UNIT_SIZE_MOBILE=320x100
# 配信切り分け用。on で data-adtest=on を付与（検証後は未設定に戻す）。
# NEXT_PUBLIC_ADSENSE_ADTEST=on
# 検証用。広告の状態（slot/size/push/scriptLoaded など）を画面表示。
# NEXT_PUBLIC_ADSENSE_DEBUG=on
# 検証用。モバイルで data-ad-status=unfilled の場合にフォールバック枠へ切替。
# NEXT_PUBLIC_ADSENSE_FALLBACK=on
# NEXT_PUBLIC_ADSENSE_FALLBACK_DELAY_MS=9000
# NEXT_PUBLIC_ADSENSE_SLOT_FALLBACK=zzzzzzzzzz
# NEXT_PUBLIC_ADSENSE_FALLBACK_UNIT_SIZE=300x250
# NEXT_PUBLIC_ADSENSE_UNIT_SIZE=320x100
# NEXT_PUBLIC_ADSENSE_UNIT_SIZE=300x250
# 将来、「メール等でログイン済み（匿名以外）は広告非表示」にするとき true。
# 既定は false のため、現状はログイン中も広告が表示されます。
# NEXT_PUBLIC_ADSENSE_HIDE_FOR_SIGNED_IN_USERS=false

# 任意。お知らせ詳細（/app/announcements/[slug]）専用のディスプレイ枠。
# 上部・左柱・右柱は別ユニット（別 data-ad-slot）を AdSense で作成し、それぞれの slot を指定すること。
# 未設定の位置には枠を出さない。左右柱は lg 未満では非表示。
# NEXT_PUBLIC_ADSENSE_SLOT_ANNOUNCEMENTS_TOP=
# NEXT_PUBLIC_ADSENSE_SLOT_ANNOUNCEMENTS_LEFT=
# NEXT_PUBLIC_ADSENSE_SLOT_ANNOUNCEMENTS_RIGHT=

# --- 開発者向け利用統計 API（/api/admin/user-stats）---
# カンマ区切りのメールアドレス。ここに含まれるユーザーのみ ID トークン検証後に集計を実行できる。
# 未設定または空のときは誰も開発者として扱われない（probe も 403/503）。
# DEVELOPER_ADMIN_EMAILS=you@example.com,other@example.com
#
# Firebase Admin SDK 用サービスアカウント JSON（プロジェクト設定 → サービスアカウント → 鍵を追加）。
# 改行を含む private_key は .env では \n とエスケープするか、BASE64 の方を推奨。
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# または JSON ファイル全体を Base64（1行）にした値:
# FIREBASE_SERVICE_ACCOUNT_BASE64=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50Ii...
