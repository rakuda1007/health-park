# =============================================================================
# このファイルは「ひな型」です。実際の値はプロジェクト直下の .env.local に書きます。
#
# 手順:
#   1. このファイルをコピーして .env.local を新規作成する（名前は .env.local 固定）
#   2. 各 KEY の右側に、下の説明どおり「値」を貼る
#   3. .env.local は Git に含めない（通常は .gitignore 済み）
#
# 開発サーバーは .env.local を読み込みます。変更したら `npm run dev` を再起動。
# =============================================================================

# 任意。本番の Health Park のトップ URL（末尾 / なし）。OGP・canonical の絶対 URL 用。
# 未設定時は Vercel なら VERCEL_URL、それ以外は metadataBase なし（相対パスのみ）。
# NEXT_PUBLIC_SITE_URL=https://health.tennis-park-community.com

# Firebase コンソール → プロジェクトの設定 → 全般 → マイアプリ → SDK の設定・構成
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Analytics を使う場合のみ
# NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# 地図等を使う場合（Google Cloud で API を有効化）
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- お知らせ（ブログ API）---
# ヘルス用ブログをブラウザで開いたときのアドレスバーと「同じホスト」の https URL。
# 例: https://blog-health.tennis-park-community.com  （末尾に / は付けない）
# 【禁止】Health Park 自身（health.tennis-park-community.com）を入れないこと。
#   ブログ専用ホストと異なる。誤ると /api/blog が 404 になる。
# 本番の確定ドメインは Web／インフラ担当に確認すること。
NEXT_PUBLIC_HEALTH_BLOG_ORIGIN=
# アプリは同一オリジン /api/health-blog を経由してブログ /api/blog を取得する。
# ブラウザが別ドメインを直接叩かないため、通常はブログ側の CORS 設定は不要。

# 任意。一覧 API の `tag` / `category` クエリ用。ブログ管理の「タグ・カテゴリの slug」と
# 一致させる。誤ると 0 件になるため、迷ったら両方とも空にして /api/blog が全件返るか先に確認。
# 値は GET .../api/blog/tags 等でブログ担当に確認。
# NEXT_PUBLIC_HEALTH_BLOG_TAG=
# 公開先が「カテゴリ」で管理されている場合に使用（API の category パラメータ）
# NEXT_PUBLIC_HEALTH_BLOG_CATEGORY=
# 記事の publicationTarget フィールドで絞る（ブログ API がクエリ対応している場合のみ）
# 例: health。記事が tennis のままだと、このフィルタではヒットしない。
# 単記事取得（/api/health-blog/[slug]）にも同じ 3 つを付与する。一覧に出るのに記事で 404 になるのを防ぐ。
# NEXT_PUBLIC_HEALTH_BLOG_PUBLICATION_TARGET=

# --- Google AdSense（記録ページのフォーム直下に固定サイズで表示）---
# tennis-park-community.com 承認済みの同一パブリッシャー ID・ユニット slot を指定。
# 両方とも未設定のときは広告コンポーネントは何も描画しません。
# NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-xxxxxxxxxxxxxxxx
# NEXT_PUBLIC_ADSENSE_SLOT=xxxxxxxxxx
# （検証用）モバイルだけ別ユニットにしたい場合に使用。未設定なら共通 slot。
# NEXT_PUBLIC_ADSENSE_SLOT_MOBILE=yyyyyyyyyy
# 広告枠サイズ（固定）。未設定または 320x100（既定）／300x250 のみ対応。
# NEXT_PUBLIC_ADSENSE_UNIT_SIZE=320x100
# NEXT_PUBLIC_ADSENSE_UNIT_SIZE=300x250
# 将来、「メール等でログイン済み（匿名以外）は広告非表示」にするとき true。
# 既定は false のため、現状はログイン中も広告が表示されます。
# NEXT_PUBLIC_ADSENSE_HIDE_FOR_SIGNED_IN_USERS=false
